<% if false %>
    <%= form_tag('/users') do %>
        <%= label_tag 'username' %>
        <%= text_field_tag 'username' %><br>
        <%= label_tag 'email' %>
        <%= email_field_tag 'email' %><br>
        <%= label_tag 'password' %>
        <%= password_field_tag 'password' %><br>
        <%= submit_tag 'Submit' %>
    <% end %>
<% end %>

<%= form_for @user do |f| %>
    <%= f.label :username %>
    <%= f.text_field :username %>
    <br>
    <%= f.label :email %>
    <%= f.email_field :email %>
    <br>
    <%= f.label :password %>
    <%= f.password_field :password %>
    <br>
    <%= f.submit 'Submit' %>

<% end %>